{
    "variable": [
        {
            "id": "baseUrl",
            "key": "baseUrl",
            "type": "string",
            "name": "string",
            "value": "http:\/\/127.0.0.1:8000"
        }
    ],
    "info": {
        "name": "DOMPET Backend API API Documentation",
        "_postman_id": "12042df1-60b6-4800-b78d-6876ebebc91a",
        "description": "Dokumentasi endpoint API untuk backend DOMPET\/Zaku.",
        "schema": "https:\/\/schema.getpostman.com\/json\/collection\/v2.1.0\/collection.json"
    },
    "item": [
        {
            "name": "Authentication",
            "description": "",
            "item": [
                {
                    "name": "Register user",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/auth\/register",
                            "query": [],
                            "raw": "{{baseUrl}}\/api\/auth\/register"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"email\":\"user@example.com\",\"password\":\"password123\",\"full_name\":\"John Doe\",\"phone_number\":\"08123456789\"}"
                        },
                        "description": "Membuat user baru, wallet default, kode verifikasi email, dan JWT token.",
                        "auth": {
                            "type": "noauth"
                        }
                    },
                    "response": [
                        {
                            "header": [],
                            "code": 201,
                            "body": "{\n  \"status\": \"success\",\n  \"message\": \"User registered successfully\",\n  \"data\": {\n    \"user\": {\n      \"id\": 1,\n      \"full_name\": \"John Doe\",\n      \"email\": \"user@example.com\",\n      \"phone_number\": \"08123456789\",\n      \"is_verified\": false,\n      \"last_login_at\": null,\n      \"wallet\": {\n        \"id\": 1,\n        \"user_id\": 1,\n        \"balance\": \"0.00\",\n        \"status\": \"active\"\n      }\n    },\n    \"token\": \"jwt_token_here\"\n  }\n}",
                            "name": ""
                        }
                    ]
                },
                {
                    "name": "Login user",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/auth\/login",
                            "query": [],
                            "raw": "{{baseUrl}}\/api\/auth\/login"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"email\":\"user@example.com\",\"password\":\"password123\"}"
                        },
                        "description": "Mengautentikasi user yang email-nya sudah diverifikasi dan mengembalikan JWT token.",
                        "auth": {
                            "type": "noauth"
                        }
                    },
                    "response": [
                        {
                            "header": [],
                            "code": 200,
                            "body": "{\n  \"status\": \"success\",\n  \"message\": \"Login successful\",\n  \"data\": {\n    \"token\": \"jwt_token_here\",\n    \"user\": {\n      \"id\": 1,\n      \"full_name\": \"John Doe\",\n      \"email\": \"user@example.com\",\n      \"is_verified\": true\n    }\n  }\n}",
                            "name": ""
                        },
                        {
                            "header": [],
                            "code": 401,
                            "body": "{\n  \"status\": \"error\",\n  \"message\": \"Invalid credentials.\"\n}",
                            "name": ""
                        },
                        {
                            "header": [],
                            "code": 403,
                            "body": "{\n  \"status\": \"error\",\n  \"message\": \"Email address is not verified.\"\n}",
                            "name": ""
                        }
                    ]
                },
                {
                    "name": "Verify email",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/auth\/verify-email",
                            "query": [],
                            "raw": "{{baseUrl}}\/api\/auth\/verify-email"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"user_id\":1,\"code\":\"123456\"}"
                        },
                        "description": "Memvalidasi kode verifikasi dan menandai email user sebagai terverifikasi.",
                        "auth": {
                            "type": "noauth"
                        }
                    },
                    "response": [
                        {
                            "header": [],
                            "code": 200,
                            "body": "{\n  \"status\": \"success\",\n  \"message\": \"Email verified successfully\"\n}",
                            "name": ""
                        },
                        {
                            "header": [],
                            "code": 422,
                            "body": "{\n  \"status\": \"error\",\n  \"message\": \"Verification code has expired.\"\n}",
                            "name": ""
                        }
                    ]
                },
                {
                    "name": "Resend verification code",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/auth\/resend-verification",
                            "query": [],
                            "raw": "{{baseUrl}}\/api\/auth\/resend-verification"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"email\":\"user@example.com\"}"
                        },
                        "description": "Mengirim ulang kode verifikasi untuk user yang belum terverifikasi.",
                        "auth": {
                            "type": "noauth"
                        }
                    },
                    "response": [
                        {
                            "header": [],
                            "code": 200,
                            "body": "{\n  \"status\": \"success\",\n  \"message\": \"Verification code sent to your email\"\n}",
                            "name": ""
                        }
                    ]
                },
                {
                    "name": "Forgot password",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/auth\/forgot-password",
                            "query": [],
                            "raw": "{{baseUrl}}\/api\/auth\/forgot-password"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"email\":\"user@example.com\"}"
                        },
                        "description": "Membuat token reset password dan mengirimkannya ke email user.",
                        "auth": {
                            "type": "noauth"
                        }
                    },
                    "response": [
                        {
                            "header": [],
                            "code": 200,
                            "body": "{\n  \"status\": \"success\",\n  \"message\": \"Password reset link sent to your email\"\n}",
                            "name": ""
                        }
                    ]
                },
                {
                    "name": "Change password",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/auth\/change-password",
                            "query": [],
                            "raw": "{{baseUrl}}\/api\/auth\/change-password"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"old_password\":\"password123\",\"new_password\":\"password456\",\"new_password_confirmation\":\"password456\"}"
                        },
                        "description": "Mengubah password user yang sedang login. Endpoint ini membutuhkan JWT Bearer token."
                    },
                    "response": [
                        {
                            "header": [],
                            "code": 200,
                            "body": "{\n  \"status\": \"success\",\n  \"message\": \"Password changed successfully\"\n}",
                            "name": ""
                        },
                        {
                            "header": [],
                            "code": 401,
                            "body": "{\n  \"status\": \"error\",\n  \"message\": \"Authorization token is required.\"\n}",
                            "name": ""
                        }
                    ]
                }
            ]
        }
    ],
    "auth": {
        "type": "bearer",
        "bearer": [
            {
                "key": "Authorization",
                "type": "string"
            }
        ]
    }
}